```vue
<script setup lang="ts">
interface Props {
  node: GoalNode
  filter: FilterQuery
}

const props = defineProps<Props>()
const expanded = ref(false)  // Default: collapsed

// Auto-expand if filter matches this node or any descendant
watchEffect(() => {
  if (matchesFilter(props.node, props.filter)) {
    expanded.value = true
  }
})

function matchesFilter(node: GoalNode, filter: FilterQuery): boolean {
  // Search across all levels
  const selfMatch = 
    node.id.toLowerCase().includes(filter.query) ||
    node.title.toLowerCase().includes(filter.query)
  
  const childMatch = node.children.some(child => 
    matchesFilter(child, filter)
  )
  
  return selfMatch || childMatch
}
</script>

<template>
  <div class="goal-node">
    <!-- Node Header -->
    <div class="goal-header" :class="{ 'has-children': node.children.length > 0 }">
      <ExpandCollapseButton 
        v-if="node.children.length > 0"
        :expanded="expanded"
        @toggle="expanded = !expanded"
      />
      
      <span class="goal-id">{{ node.id }}</span>
      <span class="goal-title">{{ node.title }}</span>
      
      <StatusBadge :status="node.status" />
      <span v-if="node.priority" class="priority">{{ node.priority }}</span>
      
      <!-- Typed Tag Badges -->
      <TagBadge 
        v-for="tag in node.tags" 
        :key="tag.kind + ':' + tag.value"
        :tag="tag"
      />
    </div>
    
    <!-- Children (recursive) -->
    <div v-if="expanded" class="goal-children">
      <GoalNode 
        v-for="child in node.children" 
        :key="child.id"
        :node="child"
        :filter="filter"
      />
    </div>
  </div>
</template>
```

