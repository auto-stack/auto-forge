}

interface AutoDownEditorEvents {
  'update': [markdown: string]     // Debounced on every change
  'save': [markdown: string]       // Ctrl+S
  'blur': []
  'focus': []
}

// Extension factory
function createExtensions(options?: EditorOptions): Extension[]

