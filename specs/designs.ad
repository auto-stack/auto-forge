```rust
// provider/claude.rs
pub struct ClaudeProvider {
    pub(crate) client: reqwest::Client,
    pub(crate) api_key: Option<String>,
    pub(crate) base_url: String,
}

impl ClaudeProvider {
    pub fn new() -> Self;
    pub fn is_available(&self) -> bool;
    pub async fn chat_stream(&self, request: AIRequest, tx: UnboundedSender<AIStreamDelta>) -> Option<String>;
    pub async fn chat(&self, request: AIRequest) -> AIResponse;
    pub async fn chat_turn(&self, request: ToolChatRequest, tx: UnboundedSender<ToolChatEvent>) -> Option<String>;
}

// provider/sse.rs
pub struct SseParser { buffer: Vec<u8> }

impl SseParser {
    pub fn new() -> Self;
    pub fn push(&mut self, chunk: &[u8]) -> Result<Vec<StreamEvent>, SseError>;
    pub fn finish(self) -> Result<Vec<StreamEvent>, SseError>;
}
```

```mermaid
stateDiagram-v2
    [*] --> Idle
    Idle --> Streaming: HTTP response received
    Streaming --> Parsing: SSE chunk arrives
    Parsing --> Emitting: complete frame found
    Emitting --> Streaming: more chunks
    Emitting --> Done: stream ends
    Parsing --> Done: stream ends
    Done --> [*]
```

| Field | Type | Description |
|---|---|---|
| `client` | `reqwest::Client` | Reusable HTTP client |
| `api_key` | `Option<String>` | Loaded from ~/.claude/settings.json or env |
| `base_url` | `String` | API endpoint (default: https://api.anthropic.com) |

