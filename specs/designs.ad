    pub handoff: HandoffDocument,
    pub file_manifest: Vec<FileState>,
    pub token_usage: TokenUsage,
}

pub struct FileState {
    pub path: String,
    pub hash: String,  // SHA-256
    pub size: u64,
}

impl Checkpoint {
    /// Create checkpoint from current pipeline state.
    pub async fn create(engine: &PipelineEngine) -> Result<Self, CheckpointError>;

    /// Serialize to disk.
    pub fn save(&self, dir: &Path) -> Result<(), CheckpointError>;

    /// Load from disk.
    pub fn load(dir: &Path, checkpoint_id: u64) -> Result<Self, CheckpointError>;

    /// Restore file system state from checkpoint.
    pub async fn restore_files(&self, project_dir: &Path) -> Result<(), CheckpointError>;

    /// Restore git state.
    pub async fn restore_git(&self) -> Result<(), CheckpointError>;
}
```

```mermaid
stateDiagram-v2
    [*] --> Capturing: Handoff triggered
    Capturing --> GitSnapshot: File manifest built
    GitSnapshot --> LedgerSnapshot: Git commit or diff captured
    LedgerSnapshot --> Serializing: Ledger embedded
    Serializing --> Persisted: JSON written to disk
    Persisted --> [*]
```

| Field | Type | Description |
|---|---|---|
| `id` | `u64` | Monotonic within run |
| `git_commit` | `Option<String>` | Full SHA if auto-commit succeeded |
| `git_diff` | `Option<String>` | Patch if working tree was dirty |
| `ledger_state` | `SpecsDocument` | Deep copy of specs at this point |
| `file_manifest` | `Vec<FileState>` | Hash of every touched file |


