pub enum RelayMode {
    GSD,      // Get Shit Done — autonomous, only GoalGate is human
    Check,    // Human reviews every gate
}

pub enum ForgePhase {
    Intake,
    Discovery,
    GoalGate,
    Design,
    Planning,
    Execution,
    Verification,
    Report,
}

pub struct PipelineEngine {
    pub flow: FlowSpec,
    pub current_step: usize,
    pub current_agent: Option<AgentInstance>,
    pub checkpoints: Vec<Checkpoint>,
    pub status: PipelineStatus,
    pub run_id: String,
    pub mode: RelayMode,  // NEW
}

impl PipelineEngine {
    /// Evaluate gate based on RelayMode.
    /// GSD: only GoalGate triggers human pause.
    /// Check: every gate triggers human pause.
    pub fn evaluate_gate(&self, step: &FlowStep) -> GateDecision;
}
```

| Field | Type | Description |
|---|---|---|
| `mode` | `RelayMode` | GSD (default) or Check |
| `phase` | `ForgePhase` | Extended to 8 phases including Discovery, GoalGate, Design, Planning, Report |

```
fn evaluate_gate(step, mode):
    if mode == Check:
        return HumanGate
    if mode == GSD:
        if step.profession == "advisor" and step.exit == "handoff_to_architect":
            return HumanGate  // Goal approval required
        return AutoGate  // Everything else autonomous
```

