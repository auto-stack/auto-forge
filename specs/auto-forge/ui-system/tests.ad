## UiSystem-T5 [UiSystem-D4] i18n 集成覆盖率和硬编码字符串检测
**Status:** draft

**状态：** 草案
**测试文件：** `frontend/src/i18n/__tests__/i18n.spec.ts`
**标签：** stack:frontend
**依赖：** UiSystem-D4

更新后的测试文件验证：

1. **键对等性**：en.json 和 zh.json 具有相同的键结构（捕获缺失的 zh 键）
2. **必需分区**：两种语言环境中均存在全部 18 个顶级分区
3. **视图集成**：6 个目标视图从 `vue-i18n` 导入 `useI18n`
4. **硬编码字符串检测**：扫描 6 个目标视图中的未翻译英文字符串
5. **localStorage 模拟**：使用 `vi.spyOn(Storage.prototype, ...)` 避免 jsdom 冲突
6. **无空值**：两种语言环境中所有键均具有非空字符串值

```typescript
import { describe, it, expect, beforeEach, vi } from 'vitest'
import { createI18n } from 'vue-i18n'
import en from '../locales/en.json'
import zh from '../locales/zh.json'
import { readFileSync } from 'fs'
import { resolve } from 'path'

function collectKeys(obj: Record&lt;string, unknown&gt;, prefix = ''): string[] {
  const keys: string[] = []
  for (const [key, value] of Object.entries(obj)) {
    const fullKey = prefix ? `${prefix}.${key}` : key
    if (value && typeof value === 'object' && !Array.isArray(value)) {
      keys.push(...collectKeys(value as Record&lt;string, unknown&gt;, fullKey))
    } else {
      keys.push(fullKey)
    }
  }
  return keys
}

describe('i18n setup', () => {
  it('creates i18n with legacy: false and fallbackLocale: en', () => {
    const i18n = createI18n({
      legacy: false,
      locale: 'en',
      fallbackLocale: 'en',
      messages: { en, zh },
    })
    expect(i18n.mode).toBe('composition')
    expect(i18n.global.fallbackLocale.value).toBe('en')
  })

  it('loads both en and zh message objects', () => {
    const i18n = createI18n({
      legacy: false,
      locale: 'en',
      fallbackLocale: 'en',
      messages: { en, zh },
    })
    const enKeys = Object.keys(i18n.global.getLocaleMessage('en'))
    const zhKeys = Object.keys(i18n.global.getLocaleMessage('zh'))
    expect(enKeys.length).toBeGreaterThan(0)
    expect(zhKeys.length).toBeGreaterThan(0)
  })
})

describe('locale detection', () => {
  it('detectLocale logic: stored value takes priority', () => {
    const store: Record&lt;string, string&gt; = { 'autoforge-language': 'zh' }
    const stored = store['autoforge-language']
    const isValid = stored && ['en', 'zh'].includes(stored)
    expect(isValid).toBe(true)
  })

  it('detectLocale logic: invalid stored value rejected', () => {
    const store: Record&lt;string, string&gt; = { 'autoforge-language': 'fr' }
    const stored = store['autoforge-language']
    const isValid = stored && ['en', 'zh'].includes(stored)
    expect(isValid).toBe(false)
  })

  it('detectLocale logic: Chinese browser maps to zh', () => {
    const nav = 'zh-CN'.toLowerCase()
    expect(nav.startsWith('zh')).toBe(true)
  })

  it('detectLocale logic: English browser maps to en', () => {
    const nav = 'en-US'.toLowerCase()
    expect(nav.startsWith('zh')).toBe(false)
  })
})

describe('setLocale', () => {
  let store: Record&lt;string, string&gt;

  beforeEach(() => {
    store = {}
  })

  it('setLocale persists to localStorage', () => {
    store['autoforge-language'] = 'zh'
    expect(store['autoforge-language']).toBe('zh')
  })

  it('setLocale sets document lang attribute', () => {
    document.documentElement.setAttribute('lang', 'zh')
    expect(document.documentElement.getAttribute('lang')).toBe('zh')
  })

  it('toggleLocale switches between en and zh', () => {
    store['autoforge-language'] = 'en'
    let current = store['autoforge-language']
    const toggled = current === 'en' ? 'zh' : 'en'
    store['autoforge-language'] = toggled
    expect(store['autoforge-language']).toBe('zh')
  })
})

describe('translation file parity', () => {
  it('en.json and zh.json have identical key structures', () => {
    const enKeys = collectKeys(en as unknown as Record&lt;string, unknown&gt;).sort()
    const zhKeys = collectKeys(zh as unknown as Record&lt;string, unknown&gt;).sort()
    expect(zhKeys).toEqual(enKeys)
  })

  it('all required top-level sections exist in both files', () => {
    const sections = ['app', 'nav', 'settings', 'common', 'welcome', 'chat', 'specs', 'wiki', 'explorer', 'relay', 'agents', 'professions', 'skills', 'apis', 'gate', 'report', 'category', 'detail']
    for (const section of sections) {
      expect(en[section as keyof typeof en]).toBeDefined()
      expect(zh[section as keyof typeof zh]).toBeDefined()
    }
  })

  it('agents section has all required i18n keys', () => {
    const required = ['title', 'loading', 'noAgents', 'createAgent', 'agentName', 'profession', 'soul', 'apiSource', 'modelTier', 'equippedSkills', 'temperature', 'maxTokens', 'reasoningBudget', 'thinkingMode', 'thinkingHint', 'thinkingBudget']
    for (const key of required) {
      expect((en.agents as Record&lt;string, string&gt;)[key], `Missing agents.${key} in en.json`).toBeDefined()
      expect((zh.agents as Record&lt;string, string&gt;)[key], `Missing agents.${key} in zh.json`).toBeDefined()
    }
  })

  it('professions section has all required i18n keys', () => {
    const required = ['title', 'loading', 'noProfessions', 'addProfession', 'phase', 'maxTurns', 'tokenBudget', 'ownedSections', 'readableSections', 'allowedTools', 'handoffTo', 'approvalGates', 'dispatchableTo']
    for (const key of required) {
      expect((en.professions as Record&lt;string, string&gt;)[key], `Missing professions.${key} in en.json`).toBeDefined()
      expect((zh.professions as Record&lt;string, string&gt;)[key], `Missing professions.${key} in zh.json`).toBeDefined()
    }
  })

  it('skills section has all required i18n keys', () => {
    const required = ['title', 'loading', 'noSkills', 'addSkill', 'grantedTools', 'promptFragment', 'extraTurns', 'extraTokenBudget']
    for (const key of required) {
      expect((en.skills as Record&lt;string, string&gt;)[key], `Missing skills.${key} in en.json`).toBeDefined()
      expect((zh.skills as Record&lt;string, string&gt;)[key], `Missing skills.${key} in zh.json`).toBeDefined()
    }
  })

  it('apis section has all required i18n keys', () => {
    const required = ['title', 'addSource', 'addManually', 'loading', 'noSources', 'scanForConfigs', 'scanning', 'testConnection', 'testing', 'provider', 'providerAnthropic', 'providerOpenai', 'providerLocal', 'name', 'apiKey', 'apiKeyEnvVar', 'optional', 'baseUrl', 'models', 'modelId', 'displayName', 'tier', 'addModel', 'selectSource', 'deleteConfirm']
    for (const key of required) {
      expect((en.apis as Record&lt;string, string&gt;)[key], `Missing apis.${key} in en.json`).toBeDefined()
      expect((zh.apis as Record&lt;string, string&gt;)[key], `Missing apis.${key} in zh.json`).toBeDefined()
    }
  })

  it('nav section has all 9 navigation keys', () => {
    const navKeys = ['explorer', 'chat', 'specs', 'wiki', 'relay', 'agents', 'professions', 'skills', 'apis']
    for (const key of navKeys) {
      expect((en.nav as Record&lt;string, string&gt;)[key]).toBeDefined()
      expect((zh.nav as Record&lt;string, string&gt;)[key]).toBeDefined()
    }
  })

  it('common section has standard action labels in both locales', () => {
    expect(en.common.save).toBe('Save')
    expect(zh.common.save).toBe('保存')
    expect(en.common.cancel).toBe('Cancel')
    expect(zh.common.cancel).toBe('取消')
    expect(en.common.delete).toBe('Delete')
    expect(zh.common.delete).toBe('删除')
    expect(en.common.edit).toBe('Edit')
    expect(zh.common.edit).toBe('编辑')
    expect(en.common.reset).toBe('Reset Defaults')
    expect(zh.common.reset).toBe('重置默认值')
  })

  it('no empty string values in en.json', () => {
    const enKeys = collectKeys(en as unknown as Record&lt;string, unknown&gt;)
    for (const key of enKeys) {
      const parts = key.split('.')
      let val: unknown = en
      for (const p of parts) val = (val as Record&lt;string, unknown&gt;)[p]
      expect(val, `Key "${key}" has empty value in en.json`).toBeTruthy()
    }
  })

  it('no empty string values in zh.json', () => {
    const zhKeys = collectKeys(zh as unknown as Record&lt;string, unknown&gt;)
    for (const key of zhKeys) {
      const parts = key.split('.')
      let val: unknown = zh
      for (const p of parts) val = (val as Record&lt;string, unknown&gt;)[p]
      expect(val, `Key "${key}" has empty value in zh.json`).toBeTruthy()
    }
  })

  it('brand name stays as AutoForge in both locales', () => {
    expect(en.app.brandName).toBe('AutoForge')
    expect(zh.app.brandName).toBe('AutoForge')
  })
})

describe('view i18n integration', () => {
  const viewsDir = resolve(__dirname, '../../views')
  const targetViews = [
    'ChatsView.vue',
    'WikiView.vue',
    'AgentsConfigView.vue',
    'ProfessionsView.vue',
    'SkillsView.vue',
    'ApiSourcesView.vue',
  ]

  for (const viewFile of targetViews) {
    describe(viewFile, () => {
      let source: string

      beforeAll(() => {
        source = readFileSync(resolve(viewsDir, viewFile), 'utf-8')
      })

      it('imports useI18n from vue-i18n', () => {
        expect(source).toMatch(/import\s+\{[^}]*useI18n[^}]*\}\s+from\s+['"]vue-i18n['"]/)
      })

      it('calls useI18n() in script setup', () => {
        expect(source).toMatch(/const\s+\{\s*t\s*(?:,\s*[^}]*)?\}\s*=\s*useI18n\(\)/)
      })

      it('uses t() calls in template (not just raw English strings in headings)', () => {
        const templateMatch = source.match(/<template>([\s\S]*)<\/template>/)
        if (!templateMatch) return
        const template = templateMatch[1]

        // Check h2 headings use t()
        const h2Matches = template.match(/<h2[^>]*>([^<]+)<\/h2>/g) || []
        for (const h2 of h2Matches) {
          // Should contain {{ t(' or be empty (dynamic content)
          expect(
            h2.includes("{{ t('")") || h2.includes("{{ t(") || !h2.match(/>[A-Z]/),
            `${viewFile}: h2 "${h2}" appears to have hardcoded text`
          ).toBe(true)
        }
      })

      it('uses t() for button labels with common actions', () => {
        const templateMatch = source.match(/<template>([\s\S]*)<\/template>/)
        if (!templateMatch) return
        const template = templateMatch[1]

        // Buttons with "Reset Defaults" should use t('common.reset')
        const resetButtons = template.match(/>\s*Reset Defaults\s*</g) || []
        for (const btn of resetButtons) {
          expect(
            false,
            `${viewFile}: Found hardcoded "Reset Defaults" — use t('common.reset') instead`
          ).toBe(true)
        }
      })

      it('uses t() for loading states', () => {
        const templateMatch = source.match(/<template>([\s\S]*)<\/template>/)
        if (!templateMatch) return
        const template = templateMatch[1]

        const loadingMatches = template.match(/>\s*Loading\.{0,3}\s*</g) || []
        for (const match of loadingMatches) {
          expect(
            false,
            `${viewFile}: Found hardcoded "${match.trim()}" — use t('*.loading') instead`
          ).toBe(true)
        }
      })
    })
  }
})
```


1. **ApiSourcesView.vue** — 缺少 `useI18n` 导入且 `t()` 调用数为零。测试将在 `imports useI18n from vue-i18n` 上失败。
2. **ProfessionsView.vue** — 缺少 `useI18n` 导入且 `t()` 调用数为零。测试将在 `imports useI18n from vue-i18n` 上失败。
3. **SkillsView.vue** — 缺少 `useI18n` 导入且 `t()` 调用数为零。测试将在 `imports useI18n from vue-i18n` 上失败。
4. **zh.json 缺失键** — `apis.deleteConfirm` 和 `apis.missingTiersAlert` 存在于 en.json 但不存在于 zh.json。键对等性测试将捕获此问题。


