#### 7. Test File Fix

**Problem**: Tests using `localStorage` fail because jsdom doesn't fully implement the Storage API, or because the mock leaks between tests.

**Fix pattern**:

```typescript
import { describe, it, expect, beforeEach, vi } from 'vitest'
import en from '../i18n/en.json'
import zh from '../i18n/zh.json'

describe('i18n', () => {
  beforeEach(() => {
    // Use vi.spyOn instead of vi.stubGlobal to avoid jsdom conflicts
    const store: Record<string, string> = {}
    vi.spyOn(Storage.prototype, 'getItem').mockImplementation((key: string) => store[key] ?? null)
    vi.spyOn(Storage.prototype, 'setItem').mockImplementation((key: string, value: string) => { store[key] = value })
    vi.spyOn(Storage.prototype, 'removeItem').mockImplementation((key: string) => { delete store[key] })
  })

  it('en.json has all required view sections', () => {
    const requiredSections = ['chat', 'wiki', 'agents', 'professions', 'skills', 'apiSources', 'common']
    for (const section of requiredSections) {
      expect(en[section]).toBeDefined()
    }
  })

  it('zh.json mirrors en.json key structure', () => {
    function getKeys(obj: Record<string, unknown>, prefix = ''): string[] {
      return Object.entries(obj).flatMap(([k, v]) =>
        typeof v === 'object' && v !== null
          ? getKeys(v as Record<string, unknown>, `${prefix}${k}.`)
          : [`${prefix}${k}`]
      )
    }
    const enKeys = getKeys(en).sort()
    const zhKeys = getKeys(zh).sort()
    expect(zhKeys).toEqual(enKeys)
  })
})
```

### Common Keys to Add/Verify

These `common.*` keys may already exist; verify and add missing:

| Key | en | zh |
|-----|----|----|
| `common.loading` | `"Loading..."` | `"加载中..."` |
| `common.saving` | `"Saving..."` | `"保存中..."` |
| `common.save` | `"Save"` | `"保存"` |
| `common.cancel` | `"Cancel"` | `"取消"` |
| `common.resetDefaults` | `"Reset Defaults"` | `"重置默认值"` |

### Quality Checklist

- [ ] Every `<h2>`, `<h3>`, `<label>`, `<button>`, `<p>`, `<span>` with visible text uses `t()`
- [ ] Every `title="..."` attribute uses `:title="t(...)"`
- [ ] Every `placeholder="..."` uses `:placeholder="t(...)"`
- [ ] `alert()` and `confirm()` calls use `t()` for messages
- [ ] en.json and zh.json have identical key structures
- [ ] No view crashes when locale switches
- [ ] Test file passes with fixed localStorage mock
- [ ] No regressions in already-i18n-ized ChatsView strings

## UiSystem-D4 i18n Integration Design for 6 Vue Views
**Status:** draft
**Module:** `frontend/src/views/`, `frontend/src/i18n/`
**Tags:** stack:frontend
**Depends on:** UiSystem-A4

### Overview

Mechanical replacement of all hardcoded English strings in 6 Vue views with `t()` calls. Two categories: **completion** (ChatsView, WikiView — partially done) and **new integration** (AgentsConfigView, ProfessionsView, SkillsView, ApiSourcesView — fully hardcoded).

### Implementation Pattern

Every view follows the same 3-step pattern:

```vue
<script setup lang="ts">
import { useI18n } from 'vue-i18n'
const { t } = useI18n()
// ...existing composable imports...
</script>

<template>
  <!-- Before: -->
  <h2>Agent Forge</h2>
  <p>Loading agents...</p>

  <!-- After: -->
  <h2>{{ t('agents.title') }}</h2>
  <p>{{ t('agents.loading') }}</p>
</template>
```

### State Machine (per view)

```mermaid
stateDiagram-v2
    [*] --> Audit: identify hardcoded strings
    Audit --> AddKeys: add keys to en.json/zh.json
    AddKeys --> ReplaceTemplate: replace strings in template
    ReplaceTemplate --> ReplaceScript: replace strings in script
    ReplaceScript --> Verify: run dev server
    Verify --> [*]: all strings translated
```

### Data Flow

```
[en.json / zh.json] → [vue-i18n plugin] → [useI18n().t()] → [template renders]
```

### Per-View Changes

---

