#### 4. ProfessionsView.vue — New Integration (~35 strings)

**File**: `frontend/src/views/ProfessionsView.vue` (605 lines)

Must add `import { useI18n } from 'vue-i18n'` and `const { t } = useI18n()`.

All UI strings are hardcoded. Template changes:

```vue
<!-- BEFORE: -->
<h2>Professions</h2>
<button @click="handleResetDefaults">Reset Defaults</button>
<button @click="startCreate"><Plus :size="14" /> Add Profession</button>
<div class="professions-empty">Loading professions...</div>
<p>No professions defined. Reset defaults to get started.</p>
<span class="stat">{{ prof.allowed_tools.length }} tools</span>
<span class="stat">{{ prof.max_turns }} turns</span>
<span class="stat">{{ (prof.token_budget / 1000).toFixed(0) }}k budget</span>
<button @click.stop="startEdit(prof)">Edit</button>
<h3>{{ isNew ? 'Create Profession' : editing.name }}</h3>
<label>ID</label> / <label>Name</label> / <label>Phase</label>
<label>Max Turns</label> / <label>Token Budget</label>
<label>Owned Sections</label> / <label>Readable Sections</label>
<label>Allowed Tools</label>
<label>Handoff To</label> / <label>Approval Gates</label>
<label>Dispatchable To</label> / <label>Base Skills</label>
<button @click="handleSave">{{ saving ? 'Saving...' : 'Save' }}</button>
<button @click="cancelEdit">Cancel</button>
<span>Add Profession</span>

<!-- AFTER: -->
<h2>{{ t('professions.title') }}</h2>
<button @click="handleResetDefaults">{{ t('common.resetDefaults') }}</button>
<button @click="startCreate"><Plus :size="14" /> {{ t('professions.addProfession') }}</button>
<div class="professions-empty">{{ t('professions.loading') }}</div>
<p>{{ t('professions.empty') }}</p>
<span class="stat">{{ t('professions.tools', { count: prof.allowed_tools.length }) }}</span>
<span class="stat">{{ t('professions.turns', { count: prof.max_turns }) }}</span>
<span class="stat">{{ t('professions.budget', { count: (prof.token_budget / 1000).toFixed(0) }) }}</span>
<button @click.stop="startEdit(prof)">{{ t('common.edit') }}</button>
<h3>{{ isNew ? t('professions.createProfession') : editing.name }}</h3>
<label>{{ t('professions.idLabel') }}</label> / <label>{{ t('professions.nameLabel') }}</label>
<!-- ...etc... -->
```

