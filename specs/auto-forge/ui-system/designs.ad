confirm('Delete this profession?')
confirm('Reset to default professions? Custom professions will be lost.')

// AFTER:
alert(t('professions.idNameRequired'))
confirm(t('professions.deleteConfirm'))
confirm(t('professions.resetConfirm'))
```

