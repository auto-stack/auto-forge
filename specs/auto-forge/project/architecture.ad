.tag-red { background: #ffebee; color: #c62828; }
.tag-gray { background: #f5f5f5; color: #616161; }
</style>
```

```typescript
export const useGoalsTree = defineStore('goalsTree', {
  state: () => ({
    tree: null as GoalsTree | null,
    filter: { query: '' } as FilterQuery,
    expandedState: new Map<string, boolean>(),  // 持久化展开/折叠状态
  }),
  
  actions: {
    async loadTree(project: string) {
      const response = await fetch(`/api/forge/specs/${project}/goals/tree`)
      this.tree = await response.json()
      
      // 恢复展开状态
      this.restoreExpandedState()
    },
    
    toggleExpand(nodeId: string) {
      const current = this.expandedState.get(nodeId) ?? false
      this.expandedState.set(nodeId, !current)
    },
    
    restoreExpandedState() {
      // 递归应用保存的展开状态
      function applyState(node: GoalNode) {
        if (this.expandedState.has(node.id)) {
          node.expanded = this.expandedState.get(node.id)!
        }
        node.children.forEach(applyState)
      }
      
      this.tree?.roots.forEach(applyState)
    },
  },
})
```

- 树形视图为默认视图（无扁平视图切换）
- 所有分支初始折叠（对大型树性能友好）
- 过滤器匹配时自动展开相关分支（UX 优化）
- 展开/折叠状态跨会话持久化（用户偏好）

