## Project-A2 Frontend Tree View Architecture
**Status:** draft
**Tags:** stack:frontend

```mermaid
graph TB
    subgraph "Vue 3 Components"
        GC[GoalsContainer.vue] --> GT[GoalsTree.vue]
        GT --> GN[GoalNode.vue]
        GN -->|recursive| GN
        
        GN --> TB[TagBadge.vue]
        GN --> EC[ExpandCollapseButton.vue]
        GN --> SM[StatusBadge.vue]
        
        subgraph "Composables"
            UFG[useGoalsTree]
            UFS[useFilter]
        end
        
        GC --> UFG
        GC --> UFS
        UFG --> GT
        UFS --> GT
    end
```

```vue
<script setup lang="ts">
interface Props {
  node: GoalNode
  filter: FilterQuery
}

const props = defineProps<Props>()
const expanded = ref(false)  // Default: collapsed

// Auto-expand if filter matches this node or any descendant
watchEffect(() => {
  if (matchesFilter(props.node, props.filter)) {
    expanded.value = true
  }
})

function matchesFilter(node: GoalNode, filter: FilterQuery): boolean {
  // Search across all levels
  const selfMatch = 
    node.id.toLowerCase().includes(filter.query) ||
    node.title.toLowerCase().includes(filter.query)
  
  const childMatch = node.children.some(child => 
    matchesFilter(child, filter)
  )
  
  return selfMatch || childMatch
}
</script>

<template>
  <div class="goal-node">
    <!-- Node Header -->
    <div class="goal-header" :class="{ 'has-children': node.children.length > 0 }">
      <ExpandCollapseButton 
        v-if="node.children.length > 0"
        :expanded="expanded"
        @toggle="expanded = !expanded"
      />
      
      <span class="goal-id">{{ node.id }}</span>
      <span class="goal-title">{{ node.title }}</span>
      
      <StatusBadge :status="node.status" />
      <span v-if="node.priority" class="priority">{{ node.priority }}</span>
      
      <!-- Typed Tag Badges -->
      <TagBadge 
        v-for="tag in node.tags" 
        :key="tag.kind + ':' + tag.value"
        :tag="tag"
      />
    </div>
    
    <!-- Children (recursive) -->
    <div v-if="expanded" class="goal-children">
      <GoalNode 
        v-for="child in node.children" 
        :key="child.id"
        :node="child"
        :filter="filter"
      />
    </div>
  </div>
</template>
```

```vue
<script setup lang="ts">
interface Props {
  tag: Tag
}

const props = defineProps<Props>()

// Color coding by tag kind
const kindColors: Record<string, string> = {
  module: 'blue',
  team: 'green',
  priority: 'red',
  status: 'gray',
}

const color = computed(() => kindColors[props.tag.kind] || 'gray')
</script>

<template>
  <span class="tag-badge" :class="`tag-${color}`">
    {{ tag.kind }}:{{ tag.value }}
  </span>
</template>

<style scoped>
.tag-badge {
  padding: 2px 6px;
  border-radius: 4px;
  font-size: 0.75rem;
  margin-left: 4px;
}

.tag-blue { background: #e3f2fd; color: #1565c0; }
.tag-green { background: #e8f5e9; color: #2e7d32; }
.tag-red { background: #ffebee; color: #c62828; }
.tag-gray { background: #f5f5f5; color: #616161; }
</style>
```

```typescript
export const useGoalsTree = defineStore('goalsTree', {
  state: () => ({
    tree: null as GoalsTree | null,
    filter: { query: '' } as FilterQuery,
    expandedState: new Map<string, boolean>(),  // Persist expand/collapse
  }),
  
  actions: {
    async loadTree(project: string) {
      const response = await fetch(`/api/forge/specs/${project}/goals/tree`)
      this.tree = await response.json()
      
      // Restore expanded state
      this.restoreExpandedState()
    },
    
    toggleExpand(nodeId: string) {
      const current = this.expandedState.get(nodeId) ?? false
      this.expandedState.set(nodeId, !current)
    },
    
    restoreExpandedState() {
      // Recursively apply saved expanded state
      function applyState(node: GoalNode) {
        if (this.expandedState.has(node.id)) {
          node.expanded = this.expandedState.get(node.id)!
        }
        node.children.forEach(applyState)
      }
      
      this.tree?.roots.forEach(applyState)
    },
  },
})
```

- Tree view is default (no flat view toggle)
- All branches collapsed initially (performance-friendly for large trees)
- Filter matches auto-expand relevant branches (UX optimization)
- Expand/collapse state persists across sessions (user preference)

