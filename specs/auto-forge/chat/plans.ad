#### Chat-P10.3 后端：添加 DELETE /api/sessions/all 路由

**文件**: `backend/src/forge/mod.rs`

添加路由处理器：
```rust
pub async fn delete_all_sessions_handler(
    State(state): State<AppState>
) -> Result<Json<DeleteAllResponse>, AppError> {
    let sessions_dir = state.config.data_dir().join("sessions");
    
    // 1. 删除所有会话
    let deleted_count = delete_all_sessions(&sessions_dir).await?;
    
    // 2. 创建新会话
    let new_session = create_new_session(&sessions_dir)?;
    
    let new_session_id = new_session.id.clone();
    
    Ok(Json(DeleteAllSessionsResponse {
        deleted_count,
        new_session_id,
        session: new_session,
    }))
}
```

在路由中注册：
```rust
.route("/api/sessions/all", delete(delete_all_sessions_handler))
```

#### Chat-P10.4 前端：useSessions.ts 添加 `deleteAllSessions()` 函数

**文件**: `frontend/src/composables/useSessions.ts`

添加函数实现：
```typescript
async function deleteAllSessions(): Promise<string> {
  const response = await fetch('/api/sessions/all', {
    method: 'DELETE',
  });
  
  if (!response.ok) {
    throw new Error(`删除失败: ${response.statusText}`);
  }
  
  const data: DeleteAllSessionsResponse = await response.json();
  
  // 清空会话列表
  sessions.value = [data.session];
  
  // 切换到新会话
  currentSessionId.value = data.new_session_id;
  
  // 显示成功提示
  toast.success(t('chat.deleteSuccess', { count: data.deleted_count }));
  
  return data.new_session_id;
}
```

#### Chat-P10.5 前端：ChatsView.vue 添加"删除全部"按钮

**文件**: `frontend/src/views/ChatsView.vue`

在会话列表头部添加按钮：
```vue
<template>
  <div class="sessions-header">
    <h3>{{ t('chat.sessions') }}</h3>
    <button
      @click="openDeleteDialog"
      :disabled="sessions.length === 0"
      :title="sessions.length === 0 ? t('chat.noSessionsToDelete') : t('chat.deleteAll')"
    >
      <Trash2 :size="16" />
      <span>{{ t('chat.deleteAll') }}</span>
    </button>
  </div>
  
  <!-- 确认对话框 -->
  <ConfirmDialog
    :open="isDeleteDialogOpen"
    :title="t('chat.deleteConfirmTitle')"
    :message="t('chat.deleteConfirmMessage', { count: sessions.length })"
    :confirm-text="t('chat.confirmDelete')"
    :cancel-text="t('chat.cancelDelete')"
    @confirm="handleDeleteAll"
    @cancel="isDeleteDialogOpen = false"
  />
</template>
```

#### Chat-P10.6 前端：集成确认对话框和错误处理

**文件**: `frontend/src/views/ChatsView.vue`

添加处理函数：
```typescript
const isDeleteDialogOpen = ref(false);

function openDeleteDialog() {
  isDeleteDialogOpen.value = true;
}

async function handleDeleteAll() {
  try {
    await deleteAllSessions();
    isDeleteDialogOpen.value = false;
  } catch (error) {
    console.error('删除会话失败:', error);
    toast.error(t('chat.deleteFailed'));
  }
}
```

