<template>
  <div class="sessions-header">
    <h3>{{ t('chat.sessions') }}</h3>
    <button
      @click="openDeleteDialog"
      :disabled="sessions.length === 0"
      :title="sessions.length === 0 ? t('chat.noSessionsToDelete') : t('chat.deleteAll')"
    >
      <Trash2 :size="16" />
      <span>{{ t('chat.deleteAll') }}</span>
    </button>
