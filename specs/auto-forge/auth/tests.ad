## Auth-T3 Frontend useAuth Composable — Login, register, logout, token persistence
**Status:** draft
**Test File:** `frontend/src/composables/__tests__/useAuth.spec.ts`
**Module:** auth
**Tags:** stack:frontend, module:auth
**Depends on:** Auth-D1, Auth-P1.4

### Verification Summary (Quinn — run-tests)

The `useAuth.ts` composable does NOT yet exist. Per Auth-P1.4, it's a new file to be created. These tests are ready for the coder to implement against. Tests verify the singleton pattern, login/register flows, localStorage persistence, authFetch interceptor, and computed properties.

### Test Cases

#### TC-T3.1: Login with valid credentials stores token and user in localStorage
#### TC-T3.2: Login with wrong credentials sets error and returns false
#### TC-T3.3: Register creates account and auto-logins
#### TC-T3.4: Logout clears token, user, and localStorage
#### TC-T3.5: validateStoredToken with valid token sets user
#### TC-T3.6: validateStoredToken with no token returns false
#### TC-T3.7: authFetch adds Authorization header
#### TC-T3.8: authFetch on 401 clears auth state
#### TC-T3.9: isAdmin computed reflects admin role
#### TC-T3.10: isAdmin computed is false for non-admin

### TypeScript Test Code

```typescript
import { describe, it, expect, beforeEach, vi } from 'vitest'

// Mock localStorage
const store: Record<string, string> = {}
vi.stubGlobal('localStorage', {
  getItem: (key: string) => store[key] ?? null,
  setItem: (key: string, value: string) => { store[key] = value },
  removeItem: (key: string) => { delete store[key] },
  clear: () => { Object.keys(store).forEach(k => delete store[k]) },
})

// Mock fetch
const mockFetch = vi.fn()
vi.stubGlobal('fetch', mockFetch)

describe('useAuth', () => {
  beforeEach(() => {
    localStorage.clear()
    mockFetch.mockReset()
  })

  it('login stores token on success', async () => {
    mockFetch.mockResolvedValueOnce({
      ok: true,
      status: 200,
      json: () => Promise.resolve({
        token: 'jwt-abc',
        user_id: 1,
        username: 'admin',
        roles: ['admin'],
      }),
    })
    mockFetch.mockResolvedValueOnce({
      ok: true,
      status: 200,
      json: () => Promise.resolve({
        user_id: 1,
        username: 'admin',
        roles: ['admin'],
        permissions: ['read', 'write'],
      }),
    })

    const { login, token, user, isAuthenticated } = useAuth()
    const result = await login('admin', 'admin')

    expect(result).toBe(true)
    expect(token.value).toBe('jwt-abc')
    expect(user.value?.username).toBe('admin')
    expect(isAuthenticated.value).toBe(true)
    expect(localStorage.getItem('autoforge_jwt')).toBe('jwt-abc')
  })

  it('login sets error on wrong credentials', async () => {
    mockFetch.mockResolvedValueOnce({
      ok: false,
      status: 401,
      json: () => Promise.resolve({ error: 'Invalid credentials' }),
    })

    const { login, error, token } = useAuth()
    const result = await login('admin', 'wrong')

    expect(result).toBe(false)
    expect(error.value).toBe('Invalid credentials')
    expect(token.value).toBeNull()
  })

  it('logout clears all auth state', () => {
    localStorage.setItem('autoforge_jwt', 'jwt-abc')
    localStorage.setItem('autoforge_user', JSON.stringify({ username: 'admin' }))

    const { logout, token, user } = useAuth()
    logout()

    expect(token.value).toBeNull()
    expect(user.value).toBeNull()
    expect(localStorage.getItem('autoforge_jwt')).toBeNull()
    expect(localStorage.getItem('autoforge_user')).toBeNull()
  })

  it('authFetch adds Authorization header when token exists', async () => {
    const { token } = useAuth()
    token.value = 'jwt-abc'

    mockFetch.mockResolvedValueOnce({ ok: true, status: 200 })

    await authFetch('/api/test')

    expect(mockFetch).toHaveBeenCalledWith(
      '/api/test',
      expect.objectContaining({
        headers: expect.objectContaining({
          Authorization: 'Bearer jwt-abc',
        }),
      }),
    )
  })

  it('authFetch clears auth on 401', async () => {
    const { token } = useAuth()
    token.value = 'jwt-abc'
    localStorage.setItem('autoforge_jwt', 'jwt-abc')

    mockFetch.mockResolvedValueOnce({ ok: false, status: 401 })

    await authFetch('/api/test')

    expect(token.value).toBeNull()
    expect(localStorage.getItem('autoforge_jwt')).toBeNull()
  })

  it('isAdmin is true for admin role', () => {
    const { user, isAdmin } = useAuth()
    user.value = { user_id: 1, username: 'admin', roles: ['admin', 'editor'], permissions: [] }
    expect(isAdmin.value).toBe(true)
  })

  it('isAdmin is false for non-admin role', () => {
    const { user, isAdmin } = useAuth()
    user.value = { user_id: 2, username: 'editor', roles: ['editor'], permissions: [] }
    expect(isAdmin.value).toBe(false)
  })
})
```

