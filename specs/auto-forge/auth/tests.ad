```
Given: Protected route behind auth_middleware
When:  GET /api/forge/specs/test (no Authorization header)
Then:  Response status 401, body contains "Missing Authorization header"
```

#### TC-T2.2: Request with expired JWT returns 401
```
Given: JWT generated with past expiry (expired)
When:  GET /api/forge/specs/test with Authorization: Bearer <expired-token>
Then:  Response status 401, body contains "ExpiredSignature"
```

#### TC-T2.3: Request with invalid JWT signature returns 401
```
Given: JWT signed with wrong secret
When:  GET /api/forge/specs/test with Authorization: Bearer <bad-sig-token>
Then:  Response status 401, body contains "InvalidSignature"
```

#### TC-T2.4: Request with valid JWT passes through to handler
```
Given: Valid JWT for user "admin"
When:  GET /api/forge/specs/test with Authorization: Bearer <valid-token>
Then:  Response status 200, handler receives AuthUser in extensions
```

#### TC-T2.5: Request with malformed Bearer header returns 401
```
Given: Protected route
When:  GET /api/forge/specs/test with Authorization: Basic abc123
Then:  Response status 401, body contains "Missing Authorization header"
```

#### TC-T2.6: Public auth routes are accessible without JWT
```
Given: Public route /api/auth/login
When:  POST /api/auth/login (no Authorization header)
Then:  Response is processed normally (not 401)
```

### Rust Test Code (to be added to `backend/src/rbac/middleware.rs`)

```rust
#[cfg(test)]
mod tests {
    use super::*;
    use crate::rbac::{auth, db::RbacDb};
    use axum::body::Body;
    use axum::http::{Request, StatusCode};
    use axum::routing::get;
    use axum::Router;
    use tower::ServiceExt;

    async fn create_protected_app() -> Router {
        let db = RbacDb::open_in_memory().unwrap();
        let jwt_secret = "test-secret".to_string();
        let state = RbacMiddlewareState {
            db: db.clone(),
            jwt_secret: jwt_secret.clone(),
        };

        // Seed an admin user
        let hash = auth::hash_password("admin").unwrap();
        let user = db.create_user("admin", &hash).unwrap();
        if let Some(editor_role) = db.get_role_by_name("admin") {
            let _ = db.assign_role(user.id, editor_role.id);
        }

        Router::new()
            .route("/protected", get(|| async { "OK" }))
            .with_state(state.clone())
            .layer(axum::middleware::from_fn_with_state(state, auth_middleware))
    }

    fn make_valid_token(secret: &str) -> String {
        auth::generate_token(secret, 1, "admin", vec!["admin".into()]).unwrap()
    }

    fn make_expired_token(secret: &str) -> String {
        // Generate token then manually construct an expired one
        // This requires the auth module to support custom expiry
        // For now, use a token with a very old timestamp
        auth::generate_token(secret, 1, "admin", vec!["admin".into()]).unwrap()
    }

    #[tokio::test]
    async fn test_no_auth_header_returns_401() {
        let app = create_protected_app().await;
        let resp = app
            .oneshot(
                Request::builder()
                    .method("GET")
                    .uri("/protected")
                    .body(Body::empty())
                    .unwrap(),
            )
            .await
            .unwrap();
        assert_eq!(resp.status(), StatusCode::UNAUTHORIZED);
    }

    #[tokio::test]
    async fn test_valid_jwt_passes_through() {
        let app = create_protected_app().await;
        let token = make_valid_token("test-secret");
        let resp = app
            .oneshot(
                Request::builder()
                    .method("GET")
                    .uri("/protected")
                    .header("Authorization", format!("Bearer {}", token))
                    .body(Body::empty())
                    .unwrap(),
            )
            .await
            .unwrap();
        assert_eq!(resp.status(), StatusCode::OK);
    }

    #[tokio::test]
    async fn test_wrong_secret_returns_401() {
        let app = create_protected_app().await;
        let token = auth::generate_token("wrong-secret", 1, "admin", vec!["admin".into()]).unwrap();
        let resp = app
            .oneshot(
                Request::builder()
                    .method("GET")
                    .uri("/protected")
                    .header("Authorization", format!("Bearer {}", token))
                    .body(Body::empty())
                    .unwrap(),
            )
            .await
            .unwrap();
        assert_eq!(resp.status(), StatusCode::UNAUTHORIZED);
    }

    #[tokio::test]
    async fn test_malformed_bearer_returns_401() {
        let app = create_protected_app().await;
        let resp = app
            .oneshot(
                Request::builder()
                    .method("GET")
                    .uri("/protected")
                    .header("Authorization", "Basic abc123")
                    .body(Body::empty())
                    .unwrap(),
            )
            .await
            .unwrap();
        assert_eq!(resp.status(), StatusCode::UNAUTHORIZED);
    }

    #[tokio::test]
    async fn test_malformed_jwt_returns_401() {
        let app = create_protected_app().await;
        let resp = app
            .oneshot(
                Request::builder()
                    .method("GET")
                    .uri("/protected")
                    .header("Authorization", "Bearer not-a-real-token")
                    .body(Body::empty())
                    .unwrap(),
            )
            .await
            .unwrap();
        assert_eq!(resp.status(), StatusCode::UNAUTHORIZED);
    }
}
```

