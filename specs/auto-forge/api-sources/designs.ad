#### Default Config Generation (lines ~458-467)

```rust
fn generate_default_configs(
    api_sources: &[ApiSource],
) -> Vec<AgentConfig> {
    // Use first available ApiSource as default
    let source = api_sources.first();

    let defaults: [(&str, &str, &str, ModelTier); 9] = [
        ("assistant", "Nicole", "assistant", ModelTier::Lite),
        ("advisor", "Isaac", "advisor", ModelTier::Mid),
        ("architect", "Vera", "architect", ModelTier::Pro),
        ("planner", "Felix", "planner", ModelTier::Mid),
        ("tester", "Quinn", "tester", ModelTier::Lite),
        ("coder", "Ash", "coder", ModelTier::Mid),
        ("reviewer", "Marcus", "reviewer", ModelTier::Pro),
        ("documenter", "Luna", "documenter", ModelTier::Lite),
        ("gofer", "Gus", "gofer", ModelTier::Lite),
    ];

    defaults.map(|(prof_id, name, soul_id, preferred_tier)| {
        // Find best matching model: preferred tier > any model
        let model_id = source
            .and_then(|s| s.models.iter().find(|m| m.tier == preferred_tier))
            .or_else(|| source.and_then(|s| s.models.first()))
            .map(|m| m.id.clone())
            .unwrap_or_default();

        AgentConfig {
            id: prof_id.to_string(),
            name: name.to_string(),
            profession_id: prof_id.to_string(),
            soul_id: soul_id.to_string(),
            api_source_id: source.map(|s| s.id.clone()).unwrap_or_default(),
            model_id,  // ← concrete model ID
            is_default: true,
            temperature: 0.7,
            max_tokens: 8192,
            reasoning_budget: None,
            thinking_enabled: false,
            thinking_budget: None,
            avatar_url: None,
            equipped_skills: Vec::new(),
        }
    }).to_vec()
}
```

#### Migration

When loading existing configs with `model_tier` but no `model_id`:

```rust
fn migrate_agent_config(config: &mut AgentConfig, api_sources: &[ApiSource]) {
    if config.model_id.is_empty() {
        // Legacy config: convert tier → model_id
        let source = api_sources.iter()
            .find(|s| s.id == config.api_source_id)
            .or_else(|| api_sources.first());

        config.model_id = source
            .and_then(|s| {
                // Try exact tier match first, then any model
                s.models.iter().find(|m| m.tier == config.model_tier)
                    .or_else(|| s.models.first())
            })
            .map(|m| m.id.clone())
            .unwrap_or_default();

        log::info!(
            "Migrated AgentConfig '{}': tier {:?} → model_id '{}'",
            config.id, config.model_tier, config.model_id
        );
    }
}
```


