## S65 [G28] Test Connection endpoint validates credentials
**Status:** draft
**Test File:** `backend/tests/api_source_connection.rs`
**Tags:** stack:backend, module:api-sources
**Depends on:** G28, D19

```rust
#[tokio::test]
async fn test_connection_valid_credentials() {
    let app = create_test_app();
    let response = app
        .oneshot(
            Request::builder()
                .method("POST")
                .uri("/api/forge/config/api-sources/test-anthropic/test")
                .body(Body::empty())
                .unwrap()
        )
        .await
        .unwrap();
    
    assert_eq!(response.status(), 200);
    let body = hyper::body::to_bytes(response.into_body()).await.unwrap();
    let result: ConnectionTestResult = serde_json::from_slice(&body).unwrap();
    
    assert!(result.success);
    assert!(result.models_available.len() > 0);
}

#[tokio::test]
async fn test_connection_invalid_credentials() {
    let app = create_test_app();
    // Mock invalid API key
    let response = app
        .oneshot(
            Request::builder()
                .method("POST")
                .uri("/api/forge/config/api-sources/test-invalid/test")
                .body(Body::empty())
                .unwrap()
        )
        .await
        .unwrap();
    
    assert_eq!(response.status(), 401);
}
```

- Valid credentials return 200 with list of available models
- Invalid credentials return 401 with error message
- Connection timeout returns 504

