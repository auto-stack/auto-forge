**Test File:** `backend/src/forge/mod.rs` (integration test)
**Tags:** stack:backend, module:chat
**Depends on:** G17, D24

```rust
#[test]
fn test_agent_handoff_sse_event() {
    // Verify SSE event structure
    let event = ForgeStreamEvent::AgentHandoff {
        from_agent: "Nicole".into(),
        from_profession: "assistant".into(),
        to_profession: "advisor".into(),
        to_agent: "Isaac".into(),
        classification: "NEW_GOAL".into(),
        reason: "User wants to add OAuth2".into(),
    };
    
    let json = serde_json::to_string(&event).unwrap();
    assert!(json.contains("\"type\":\"agent_handoff\""));
    assert!(json.contains("\"from_agent\":\"Nicole\""));
    assert!(json.contains("\"to_agent\":\"Isaac\""));
    assert!(json.contains("\"classification\":\"NEW_GOAL\""));
}
```

- SSE event type is `agent_handoff`
- Event includes from_agent, to_agent, from_profession, to_profession
- Classification and reason are included

