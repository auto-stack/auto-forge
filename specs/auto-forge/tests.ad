## S70 [G38] Frontend HandoffCard renders for bring_in tool calls
**Status:** draft
**Test File:** `frontend/src/views/ChatsView.vue` (component test)
**Tags:** stack:frontend, module:chat
**Depends on:** G38, D24

```typescript
describe('HandoffCard', () => {
  test('renders handoff card for bring_in tool', () => {
    const msg = {
      tool_calls: [{
        id: 'tc1',
        name: 'bring_in',
        arguments: { 
          target: 'advisor',
          classification: 'NEW_GOAL',
          reason: 'User wants OAuth2 login'
        }
      }]
    }
    
    const wrapper = mount(ChatsView, { props: { messages: [msg] } })
    const card = wrapper.find('.handoff-card')
    
    expect(card.exists()).toBe(true)
    expect(card.text()).toContain('Nicole')
    expect(card.text()).toContain('→')
    expect(card.text()).toContain('Isaac')
  })
  
  test('displays classification badge', () => {
    const msg = {
      tool_calls: [{
        name: 'bring_in',
        arguments: { classification: 'NEW_GOAL' }
      }]
    }
    
    const wrapper = mount(ChatsView, { props: { messages: [msg] } })
    const badge = wrapper.find('.handoff-badge')
    
    expect(badge.exists()).toBe(true)
    expect(badge.text()).toBe('NEW_GOAL')
  })
  
  test('updates active profession badge on handoff', async () => {
    const wrapper = mount(ChatsView)
    
    // Simulate SSE event
    await wrapper.vm.$emit('agent_handoff', {
      from_profession: 'assistant',
      to_profession: 'advisor'
    })
    
    await nextTick()
    const badge = wrapper.find('.active-profession-badge')
    expect(badge.text()).toBe('Isaac (Advisor)')
  })
})
```

- HandoffCard component renders for bring_in tool calls
- Shows agent flow (from → to)
- Displays classification badge
- Shows handoff reason
- Active profession badge updates on SSE event

