#[test]
fn test_api_source_crud() {
    use tempfile::TempDir;
    
    let temp_dir = TempDir::new().unwrap();
    let config_dir = temp_dir.path().join("autoforge");
    
    let source = ApiSource {
        id: "test-anthropic".into(),
        name: "Test Anthropic".into(),
        provider: Provider::Anthropic,
        api_key_env: "ANTHROPIC_API_KEY".into(),
        api_key_stored: None,
        base_url: None,
        is_available: true,
        models: vec![
            ModelDefinition {
                id: "claude-3-5-sonnet".into(),
                name: "Claude 3.5 Sonnet".into(),
                tier: ModelTier::Mid,
            }
        ],
    };
    
    // Test save
    save_api_sources(&config_dir, &[source.clone()]).unwrap();
    
    // Test load
    let loaded = load_api_sources(&config_dir).unwrap();
    assert_eq!(loaded.len(), 1);
    assert_eq!(loaded[0].id, "test-anthropic");
    assert_eq!(loaded[0].models.len(), 1);
    assert_eq!(loaded[0].models[0].tier, ModelTier::Mid);
}
```

- ApiSource save and load round-trips correctly
- Multiple sources can be persisted
- ModelTier enum serializes correctly

