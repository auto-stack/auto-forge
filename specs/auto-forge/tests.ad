#[test]
fn test_model_tier_display() {
    assert_eq!(ModelTier::Min.display_name(), "Min");
    assert_eq!(ModelTier::Lite.display_name(), "Lite");
    assert_eq!(ModelTier::Mid.display_name(), "Mid");
    assert_eq!(ModelTier::Large.display_name(), "Large");
    assert_eq!(ModelTier::Max.display_name(), "Max");
}

#[test]
fn test_model_tier_order() {
    assert_eq!(ModelTier::Min.order(), 0);
    assert_eq!(ModelTier::Lite.order(), 1);
    assert_eq!(ModelTier::Mid.order(), 2);
    assert_eq!(ModelTier::Large.order(), 3);
    assert_eq!(ModelTier::Max.order(), 4);
}

#[test]
fn test_model_tier_serde() {
    let tier = ModelTier::Mid;
    let json = serde_json::to_string(&tier).unwrap();
    assert_eq!(json, "\"mid\"");
    
    let decoded: ModelTier = serde_json::from_str(&json).unwrap();
    assert_eq!(decoded, ModelTier::Mid);
}
```

- All 5 tiers display correctly
- Tier order is sequential (0-4)
- Serialization/deserialization works

