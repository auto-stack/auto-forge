## Relay-D13 PDF Export for Relay Run Reports — Design
**Status:** draft

**状态：** 提议中
**文件：** `frontend/src/views/RelayView.vue`
**模块：** `frontend/src/utils/PdfGenerator.ts`, `frontend/src/views/RelayView.vue`
**标签：** stack:frontend, module:relay
**依赖：** Relay-G15, Relay-A7

### 概述

已完成接力运行的客户端 PDF 导出。使用 `jspdf` + `jspdf-autotable` 从现有 RunState 数据生成多页 PDF 文档。无需后端变更。

### 1. PdfGenerator 工具类


```typescript
import jsPDF from 'jspdf'
import autoTable from 'jspdf-autotable'

interface RunStateForPdf {
  run_id: string
  title: string
  flow_id: string
  status: string
  mode: string
  started_at: string
  completed_at: string
  tokens_used: number
  steps: StepSummary[]
  spec_changes: SpecChange[]
  deliverables: Deliverable[]
}

interface StepSummary {
  step_id: string
  profession: string
  status: string
  tokens_used: number
  elapsed_ms: number
  tool_calls: number
  handoff_summary?: string
}

interface SpecChange {
  section_id: string
  action: 'created' | 'updated' | 'deleted'
  item_ids: string[]
}

interface Deliverable {
  type: 'file' | 'spec' | 'report'
  path: string
  description?: string
}

export class PdfGenerator {
  private doc: jsPDF
  private pageWidth: number
  private margin: number
  private contentWidth: number

  constructor() {
    this.doc = new jsPDF({ orientation: 'portrait', unit: 'mm', format: 'a4' })
    this.pageWidth = this.doc.internal.pageSize.getWidth()
    this.margin = 20
    this.contentWidth = this.pageWidth - 2 * this.margin
  }

  generate(run: RunStateForPdf): jsPDF {
    this.renderCover(run)
    this.renderSummary(run)
    this.renderTimeline(run)
    if (run.spec_changes.length > 0) this.renderSpecChanges(run)
    if (run.deliverables.length > 0) this.renderDeliverables(run)
    return this.doc
  }

  save(run: RunStateForPdf): void {
    const slug = run.title
      .toLowerCase()
      .replace(/[^a-z0-9]+/g, '-')
      .slice(0, 40)
    const date = new Date().toISOString().slice(0, 10)
    this.doc.save(`relay-${slug}-${date}.pdf`)
  }

  // --- 页面渲染器（私有） ---

  private renderCover(run: RunStateForPdf): void {
    // 标题块
    this.doc.setFontSize(24)
    this.doc.setFont('helvetica', 'bold')
    this.doc.text('Relay Run Report', this.margin, 60)

    this.doc.setFontSize(12)
    this.doc.setFont('helvetica', 'normal')
    this.doc.text(run.title || run.run_id, this.margin, 72)

    // 元数据表
    const rows = [
      ['Run ID', run.run_id],
      ['Flow', run.flow_id],
      ['Status', run.status],
      ['Mode', run.mode],
      ['Started', formatTimestamp(run.started_at)],
      ['Completed', formatTimestamp(run.completed_at)],
      ['Duration', formatDuration(run.started_at, run.completed_at)],
      ['Total Tokens', run.tokens_used.toLocaleString()],
    ]
    autoTable(this.doc, {
      startY: 85,
      head: [['Field', 'Value']],
      body: rows,
      margin: { left: this.margin, right: this.margin },
      styles: { fontSize: 10 },
      headStyles: { fillColor: [59, 130, 246] }, // blue-500
    })
  }

  private renderSummary(run: RunStateForPdf): void {
    this.addPage()
    this.sectionTitle('Execution Summary')

    const totalSteps = run.steps.length
    const completedSteps = run.steps.filter(s => s.status === 'done').length
    const failedSteps = run.steps.filter(s => s.status === 'error').length
    const totalToolCalls = run.steps.reduce((sum, s) => sum + s.tool_calls, 0)
    const totalElapsedMs = run.steps.reduce((sum, s) => sum + s.elapsed_ms, 0)

    const summaryRows = [
      ['Total Steps', `${completedSteps}/${totalSteps} completed`],
      ['Failed Steps', failedSteps.toString()],
      ['Total Tool Calls', totalToolCalls.toString()],
      ['Total Duration', formatMs(totalElapsedMs)],
      ['Total Tokens', run.tokens_used.toLocaleString()],
      ['Spec Changes', run.spec_changes.length.toString()],
      ['Deliverables', run.deliverables.length.toString()],
    ]
    autoTable(this.doc, {
      startY: this.lastY() + 5,
      head: [['Metric', 'Value']],
      body: summaryRows,
      margin: { left: this.margin, right: this.margin },
      styles: { fontSize: 10 },
      headStyles: { fillColor: [59, 130, 246] },
    })

    // 每步 Token 细分
    this.sectionTitle('Per-Step Token Usage', 10)

    const stepRows = run.steps.map(s => [
      s.step_id,
      s.profession,
      s.status,
      s.tokens_used.toLocaleString(),
      formatMs(s.elapsed_ms),
      s.tool_calls.toString(),
    ])
    autoTable(this.doc, {
      startY: this.lastY() + 5,
      head: [['Step', 'Profession', 'Status', 'Tokens', 'Duration', 'Tools']],
      body: stepRows,
      margin: { left: this.margin, right: this.margin },
      styles: { fontSize: 9 },
      headStyles: { fillColor: [59, 130, 246] },
      columnStyles: {
        0: { cellWidth: 25 },
        3: { halign: 'right' },
        4: { halign: 'right' },
        5: { halign: 'right' },
      },
    })
  }

  private renderTimeline(run: RunStateForPdf): void {
    this.addPage()
    this.sectionTitle('Execution Timeline')

    const rows = run.steps.map(s => [
      formatTimestamp(s.started_at || ''),
      s.step_id,
      s.profession,
      s.status === 'done' ? '✓' : s.status === 'error' ? '✗' : '—',
      s.handoff_summary || '',
    ])
    autoTable(this.doc, {
      startY: this.lastY() + 5,
      head: [['Time', 'Step', 'Profession', 'Status', 'Handoff Note']],
      body: rows,
      margin: { left: this.margin, right: this.margin },
      styles: { fontSize: 9 },
      headStyles: { fillColor: [59, 130, 246] },
      columnStyles: {
        0: { cellWidth: 32 },
        4: { cellWidth: 'wrap' },
      },
    })
  }

  private renderSpecChanges(run: RunStateForPdf): void {
    this.addPage()
    this.sectionTitle('Spec Changes')

    const rows = run.spec_changes.map(c => [
      c.section_id,
      c.action,
      c.item_ids.join(', '),
    ])
    autoTable(this.doc, {
      startY: this.lastY() + 5,
      head: [['Section', 'Action', 'Items']],
      body: rows,
      margin: { left: this.margin, right: this.margin },
      styles: { fontSize: 10 },
      headStyles: { fillColor: [59, 130, 246] },
    })
  }

  private renderDeliverables(run: RunStateForPdf): void {
    this.addPage()
    this.sectionTitle('Deliverables')

    const rows = run.deliverables.map(d => [
      d.type,
      d.path,
      d.description || '',
    ])
    autoTable(this.doc, {
      startY: this.lastY() + 5,
      head: [['Type', 'Path', 'Description']],
      body: rows,
      margin: { left: this.margin, right: this.margin },
      styles: { fontSize: 10 },
      headStyles: { fillColor: [59, 130, 246] },
    })
  }

  // --- 辅助方法 ---

  private sectionTitle(text: string, offset = 0): void {
    const y = this.lastY() + 10 + offset
    this.doc.setFontSize(14)
    this.doc.setFont('helvetica', 'bold')
    this.doc.text(text, this.margin, y)
  }

  private addPage(): void {
    this.doc.addPage()
  }

  private lastY(): number {
    // jspdf-autotable 在每次 autoTable 调用后将 finalY 存储在 doc 上
    return (this.doc as any).lastAutoTable?.finalY ?? this.margin
  }
}

// --- 格式化器 ---

function formatTimestamp(iso: string): string {
  if (!iso) return '—'
  const d = new Date(iso)
  return d.toLocaleString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' })
}

function formatDuration(start: string, end: string): string {
  if (!start || !end) return '—'
  return formatMs(new Date(end).getTime() - new Date(start).getTime())
}

function formatMs(ms: number): string {
  if (ms < 1000) return `${ms}ms`
  if (ms < 60000) return `${(ms / 1000).toFixed(1)}s`
  const mins = Math.floor(ms / 60000)
  const secs = Math.floor((ms % 60000) / 1000)
  return `${mins}m ${secs}s`
}
```

### 2. 状态机

```mermaid
stateDiagram-v2
    [*] --> Idle: RelayView mounted
    Idle --> Generating: User clicks Export PDF
    Generating --> Generating: Build pages from RunState
    Generating --> Downloading: jsPDF.save() called
    Downloading --> Idle: Browser download completes
    Generating --> Error: jspdf throws
    Error --> Idle: User dismisses error
```

### 3. 前端集成


```vue
<!-- 在运行详情头部 -->
<button
  v-if="selectedRun?.status === 'completed'"
  @click="exportPdf"
  :disabled="exporting"
  class="export-btn"
>
  <Download :size="16" />
  {{ exporting ? t('relay.exporting') : t('relay.exportPdf') }}
</button>
```

```typescript
import { PdfGenerator } from '@/utils/PdfGenerator'

const exporting = ref(false)

async function exportPdf() {
  if (!selectedRun.value) return
  exporting.value = true
  try {
    const gen = new PdfGenerator()
    // 将 RunState 映射为 RunStateForPdf
    const pdfData = mapRunState(selectedRun.value)
    gen.generate(pdfData)
    gen.save(pdfData)
  } catch (e) {
    console.error('PDF export failed:', e)
  } finally {
    exporting.value = false
  }
}

function mapRunState(run: RunState): RunStateForPdf {
  return {
    run_id: run.run_id,
    title: run.title || run.run_id,
    flow_id: run.flow_id,
    status: run.status,
    mode: run.mode || 'gsd',
    started_at: run.started_at,
    completed_at: run.completed_at,
    tokens_used: run.tokens_used || 0,
    steps: run.steps.map(s => ({
      step_id: s.step_id,
      profession: s.profession_id,
      status: s.status,
      tokens_used: s.tokens_used || 0,
      elapsed_ms: s.elapsed_ms || 0,
      tool_calls: s.tool_calls?.length || 0,
      handoff_summary: s.handoff?.summary,
    })),
    spec_changes: run.spec_changes || [],
    deliverables: run.deliverables || [],
  }
}
```

### 4. 国际化键值

| 键 | en.json | zh.json |
|-----|---------|---------|
| `relay.exportPdf` | `"Export PDF"` | `"导出 PDF"` |
| `relay.exporting` | `"Exporting..."` | `"导出中..."` |

### 5. 依赖

| 包 | 版本 | 用途 |
|---------|---------|---------|
| `jspdf` | ^2.5.x | PDF 文档生成 |
| `jspdf-autotable` | ^3.8.x | PDF 中的表格渲染 |

两者均为轻量级（合并 gzip 后约 200KB），纯客户端，无原生依赖。

### 6. 错误处理

| 错误场景 | 处理方式 |
|------------|----------|
| 运行未完成 | 导出按钮禁用（仅对 `status === 'completed'` 显示） |
| 生成过程中 jspdf 抛出异常 | try/catch，记录错误，显示 toast 通知 |
| RunState 缺少字段 | 在格式化器中默认使用 `—` 或 `0` |
| 大型运行（50+ 步骤） | autoTable 自动处理分页 |

### 7. 数据生命周期

```
[用户点击导出]
    → mapRunState() 将前端 RunState 转换为扁平的 PdfData 接口
    → PdfGenerator.generate(pdfData) 在内存中构建页面
    → PdfGenerator.save(pdfData) 触发浏览器下载
    → 无持久化 — PDF 为一次性导出
    → 无服务器参与
```

### 8. PDF 文档结构

| 页码 | 内容 | 布局 |
|------|---------|--------|
| 1 — 封面 | 标题、运行元数据表 | 居中标题、元数据表 |
| 2 — 摘要 | 指标概览 + 每步 Token 表 | 两个 autoTable |
| 3 — 时间线 | 按时间顺序的步骤执行 | 带时间戳的 autoTable |
| 4 — 规范变更 | 修改的章节、动作、条目 ID | autoTable（可选） |
| 5 — 交付物 | 生成的文件/规范/报告 | autoTable（可选） |

第 4 和第 5 页仅在运行包含 spec_changes 或 deliverables 时包含。

### 9. 修改的文件

| 文件 | 变更 |
|------|--------|
| `frontend/package.json` | 添加 `jspdf` 和 `jspdf-autotable` 依赖 |
| `frontend/src/utils/PdfGenerator.ts` | **新文件** — PDF 生成工具类 |
| `frontend/src/views/RelayView.vue` | 添加导出按钮 + `exportPdf()` 处理函数 |
| `frontend/src/locales/en.json` | 添加 `relay.exportPdf`、`relay.exporting` |
| `frontend/src/locales/zh.json` | 添加 `relay.exportPdf`、`relay.exporting` |

### 10. 质量检查清单

- [x] 接口已定义（RunStateForPdf、步骤类型）
- [x] 状态机已定义（Idle → Generating → Downloading）
- [x] 数据模型已定义（扁平的 PDF 专用类型）
- [x] 错误场景已处理（未完成的禁用、try/catch、默认值）
- [x] 数据生命周期已定义（一次性导出，无持久化）
- [x] 所有文件路径均为新建（无需验证）
- [x] 无未处理的错误场景

