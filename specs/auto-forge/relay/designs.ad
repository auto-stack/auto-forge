## Composable: `useProfessionSegments`


### Interface

```typescript
export interface ProfessionSegment {
  profession: string
  tokens: number
  color: string
}

export interface TooltipBarEntry {
  profession: string
  tokens: number
  percentage: number  // tokens / totalUsed * 100, rounded to 1 decimal
  color: string
}

export const PROFESSION_PALETTE: Record<string, string> = {
  advisor:    '#6366f1',  // indigo
  architect:  '#8b5cf6',  // violet
  planner:    '#3b82f6',  // blue
  coder:      '#10b981',  // emerald
  tester:     '#f59e0b',  // amber
  reviewer:   '#ef4444',  // red
  documenter: '#06b6d4',  // cyan
  gofer:      '#64748b',  // slate
  _default:   '#94a3b8',  // gray
}

export function useProfessionSegments(
  professionTokens: Ref<Record<string, number>>
) {
  // Filter tokens > 0, map to segment with palette color, sort desc
  const segments = computed<ProfessionSegment[]>(() =>
    Object.entries(professionTokens.value)
      .filter(([, tokens]) => tokens > 0)
      .map(([profession, tokens]) => ({
        profession,
        tokens,
        color: PROFESSION_PALETTE[profession] ?? PROFESSION_PALETTE._default,
      }))
      .sort((a, b) => b.tokens - a.tokens)
  )

  const totalUsed = computed(() =>
    segments.value.reduce((sum, s) => sum + s.tokens, 0)
  )

  // Percentage computed to 1 decimal (e.g. 35.2)
  const tooltipEntries = computed<TooltipBarEntry[]>(() => {
    const total = totalUsed.value || 1  // avoid /0
    return segments.value.map(s => ({
      ...s,
      percentage: Math.round((s.tokens / total) * 1000) / 10,
    }))
  })

  return { segments, totalUsed, tooltipEntries }
}
```

### Data Flow

```
[useRelay()._professionTokens (reactive)]
  → useProfessionSegments(professionTokens)
  → computed: segments (filter >0, color-map, sort desc)
  → computed: totalUsed (sum of segment tokens)
  → computed: tooltipEntries (segments + percentage)
  → prop-drill into <SegmentedProgressBar> + <AgentBreakdownTooltip>
```

---

## Component 1: AgentBreakdownTooltip


### Interface

```typescript
interface Props {
  visible: boolean
  entries: TooltipBarEntry[]
  totalUsed: number
  totalBudget: number
}

// Emits — none (display-only)
```

### Template Structure

```html
<Transition name="tooltip-fade">
  <div
    v-if="visible"
    class="breakdown-tooltip"
    role="tooltip"
  >
    <div class="tooltip-title">{{ t('relay.tokenBreakdown') }}</div>
    <div class="tooltip-divider" />

    <div
      v-for="entry in entries"
      :key="entry.profession"
      class="tooltip-row"
    >
      <span class="color-dot" :style="{ background: entry.color }" />
      <span class="profession-name">{{ entry.profession }}</span>
      <div class="mini-bar-track">
        <div
          class="mini-bar-fill"
          :style="{ width: `${entry.percentage}%`, background: entry.color }"
        />
      </div>
      <span class="percentage-label">{{ entry.percentage }}%</span>
    </div>

    <div class="tooltip-divider" />
    <div class="tooltip-total">
      {{ formatTokens(totalUsed) }} / {{ formatTokens(totalBudget) }}
    </div>
  </div>
</Transition>
```

### Script

```typescript
import type { TooltipBarEntry } from '@/composables/useProfessionSegments'

function formatTokens(n: number): string {
  if (n >= 1000) return `${(n / 1000).toFixed(1)}k`
  return `${n}`
}
```

### State Machine

```mermaid
stateDiagram-v2
    [*] --> Hidden: mount
    Hidden --> Visible: parent sets visible=true
    Visible --> Hidden: parent sets visible=false
    
    note right of Hidden: DOM not rendered (v-if)
    note right of Visible: Fade-in transition 150ms
```

### CSS

```css
.breakdown-tooltip {
  position: absolute;
  bottom: calc(100% + 8px);
  left: 50%;
  transform: translateX(-50%);
  z-index: 50;
  min-width: 280px;
  max-width: 360px;
  background: var(--af-bg);
  border: 1px solid var(--af-border);
  border-radius: 8px;
  padding: 0.75rem 1rem;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
  pointer-events: none;
}

/* Flip below if near viewport top — JS sets `.flipped` class */
.breakdown-tooltip.flipped {
  bottom: auto;
  top: calc(100% + 8px);
}

.tooltip-title {
