## Component 2: SegmentedProgressBar


### Interface

```typescript
import type { ProfessionSegment } from '@/composables/useProfessionSegments'
import type { TooltipBarEntry } from '@/composables/useProfessionSegments'

interface Props {
  segments: ProfessionSegment[]
  totalBudget: number
  totalUsed: number
  warnThreshold?: number   // default 0.7
  dangerThreshold?: number // default 0.9
}

// Emits — none (display-only)
```

### Template Structure

```html
<div
  class="segmented-budget-bar"
  :class="budgetClass"
  tabindex="0"
  role="progressbar"
  :aria-valuenow="totalUsed"
  :aria-valuemax="totalBudget"
  :aria-label="`Token budget: ${formatTokens(totalUsed)} of ${formatTokens(totalBudget)} used`"
  @mouseenter="onMouseEnter"
  @mouseleave="onMouseLeave"
  @focusin="onFocusIn"
  @focusout="onFocusOut"
>
  <!-- Empty state -->
  <div v-if="segments.length === 0" class="empty-placeholder">
    No token data yet
  </div>

  <!-- Filled segments -->
  <div v-else class="segments-container">
    <div
      v-for="seg in segments"
      :key="seg.profession"
      class="segment"
      :style="segmentStyle(seg)"
    />
  </div>

  <!-- Hover tooltip -->
  <AgentBreakdownTooltip
    :visible="isTooltipVisible"
    :entries="tooltipEntries"
    :total-used="totalUsed"
    :total-budget="totalBudget"
  />
</div>
```

### Script

```typescript
import { ref, computed, watch } from 'vue'
import type { ProfessionSegment, TooltipBarEntry } from '@/composables/useProfessionSegments'
import AgentBreakdownTooltip from './AgentBreakdownTooltip.vue'

const props = withDefaults(defineProps<{
  segments: ProfessionSegment[]
  totalBudget: number
  totalUsed: number
  warnThreshold?: number
  dangerThreshold?: number
}>(), {
  warnThreshold: 0.7,
  dangerThreshold: 0.9,
})

// Budget warning class
const budgetClass = computed(() => {
  if (!props.totalBudget) return ''
  const ratio = props.totalUsed / props.totalBudget
  if (ratio >= props.dangerThreshold!) return 'budget-danger'
  if (ratio >= props.warnThreshold!) return 'budget-warn'
  return ''
})

// Segment style: proportional to budget
function segmentStyle(seg: ProfessionSegment) {
  return {
    width: props.totalBudget > 0
      ? `${(seg.tokens / props.totalBudget) * 100}%`
      : '0%',
    backgroundColor: seg.color,
    minWidth: seg.tokens > 0 ? '2px' : '0',
  }
}

// Tooltip entries — compute percentage relative to totalUsed
const tooltipEntries = computed<TooltipBarEntry[]>(() => {
  const total = props.totalUsed || 1
  return props.segments.map(s => ({
    ...s,
    percentage: Math.round((s.tokens / total) * 1000) / 10,
  }))
})

// Hover state with delays
const isHovering = ref(false)
const isTooltipVisible = ref(false)
let showTimer: ReturnType<typeof setTimeout> | null = null
let hideTimer: ReturnType<typeof setTimeout> | null = null

function showTooltip() {
  cancelTimers()
  showTimer = setTimeout(() => {
    isTooltipVisible.value = true
  }, 80)
}

function hideTooltip() {
  cancelTimers()
  hideTimer = setTimeout(() => {
    isTooltipVisible.value = false
    isHovering.value = false
  }, 150)
}

function cancelTimers() {
  if (showTimer) clearTimeout(showTimer)
  if (hideTimer) clearTimeout(hideTimer)
}

function onMouseEnter() { isHovering.value = true; showTooltip() }
function onMouseLeave() { hideTooltip() }
function onFocusIn() { isHovering.value = true; showTooltip() }
function onFocusOut() { hideTooltip() }

function formatTokens(n: number): string {
  if (n >= 1000) return `${(n / 1000).toFixed(1)}k`
  return `${n}`
}
```

### State Machine

```mermaid
stateDiagram-v2
    [*] --> Empty: mount / no tokens
    Empty --> HasSegments: first token event
    HasSegments --> HasSegments: token update (re-render segments)
    HasSegments --> Empty: run cleared (segments=[])

    state HasSegments {
        [*] --> Idle
        Idle --> Hovering: mouseenter / focusin
        Hovering --> TooltipVisible: 80ms show delay
        Hovering --> Idle: mouseleave (150ms debounce)
        TooltipVisible --> Idle: mouseleave / focusout (150ms debounce)
    }
```

### CSS

```css
.segmented-budget-bar {
  position: relative;
  height: 24px;
  border-radius: 6px;
  background: hsl(var(--muted-foreground) / 0.08);
  overflow: visible;  /* tooltip overflows */
  outline: none;
  transition: box-shadow 0.5s ease-in-out;
}

.segmented-budget-bar:focus-visible {
  outline: 2px solid hsl(var(--primary) / 0.5);
  outline-offset: 2px;
}

.segments-container {
  display: flex;
  height: 100%;
  border-radius: 6px;
  overflow: hidden;
}

.segment {
  height: 100%;
  transition: width 0.3s ease-out;
}

.segment:first-child {
  border-radius: 6px 0 0 6px;
}

.segment:last-child {
  border-radius: 0 6px 6px 0;
}

.segment:only-child {
  border-radius: 6px;
}

/* Budget warning borders */
.budget-warn {
  box-shadow: 0 0 0 2px rgba(245, 158, 11, 0.3);
}

.budget-danger {
  box-shadow: 0 0 0 2px rgba(239, 68, 68, 0.4);
}

.empty-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
  color: var(--af-muted);
  font-size: 12px;
}
```

