## Relay-D15 Segmented Token Progress Bar Design
**Status:** approved
**File:** `frontend/src/components/SegmentedProgressBar.vue` (**CREATE**)
**Module:** relay
**Depends on:** Relay-A9 (architecture), Relay-A8 (profession_tokens data)

## Overview

Detailed component design for replacing the inline Cost Breakdown pie chart panel in RelayView.vue with a multi-color segmented progress bar in the budget bar area, including a hover tooltip showing a horizontal bar chart of per-agent token usage.


---

## Composable: `useProfessionSegments`


### Exported Types

```typescript
export interface ProfessionSegment {
  profession: string
  tokens: number
  color: string
}

export interface TooltipBarEntry {
  profession: string
  tokens: number
  percentage: number  // of totalUsed, 1 decimal place
}
```

### Color Palette Constant

```typescript
export const PROFESSION_PALETTE: Record<string, string> = {
  advisor:    '#6366f1',  // indigo
  architect:  '#8b5cf6',  // violet
  planner:    '#3b82f6',  // blue
  coder:      '#10b981',  // emerald
  tester:     '#f59e0b',  // amber
  reviewer:   '#ef4444',  // red
  documenter: '#06b6d4',  // cyan
  gofer:      '#64748b',  // slate
  _default:   '#94a3b8',  // gray
}
```

### Composable Function

```typescript
import { computed, type Ref } from 'vue'

export function useProfessionSegments(professionTokens: Ref<Record<string, number>>) {
  const segments = computed<ProfessionSegment[]>(() =>
    Object.entries(professionTokens.value)
      .filter(([, tokens]) => tokens > 0)
      .map(([profession, tokens]) => ({
        profession,
        tokens,
        color: PROFESSION_PALETTE[profession] ?? PROFESSION_PALETTE._default,
      }))
      .sort((a, b) => b.tokens - a.tokens)
  )

  const totalUsed = computed(() =>
    segments.value.reduce((sum, s) => sum + s.tokens, 0)
  )

  const tooltipEntries = computed<TooltipBarEntry[]>(() => {
    const total = totalUsed.value || 1  // avoid division by zero
    return segments.value.map(s => ({
      profession: s.profession,
      tokens: s.tokens,
      percentage: Math.round((s.tokens / total) * 1000) / 10,  // 1 decimal
      color: s.color,
    }))
  })

  return { segments, totalUsed, tooltipEntries }
}
```

### Data Flow

```
[useRelay().professionTokens] → Ref<Record<string, number>>
  → useProfessionSegments(professionTokens)
    → segments: ProfessionSegment[]  (filter >0, map with color, sort desc)
    → totalUsed: number              (sum of all segment tokens)
    → tooltipEntries: TooltipBarEntry[]  (segments + percentage)
  → prop-drill into SegmentedProgressBar
```

---

## Component: `SegmentedProgressBar`


### Interface

```typescript
// Props
interface Props {
  segments: ProfessionSegment[]
  totalBudget: number
  totalUsed: number
  warnThreshold?: number   // default 0.7
  dangerThreshold?: number // default 0.9
}

// Emits — none (display-only)
```

### State Machine

```mermaid
stateDiagram-v2
    [*] --> Empty: mount / no tokens
    Empty --> HasSegments: first SSE event
    HasSegments --> HasSegments: token update
    HasSegments --> Empty: run cleared
    
    state HasSegments {
        [*] --> Idle
        Idle --> Hovering: mouseenter bar
        Hovering --> Idle: mouseleave (150ms debounce)
        Hovering --> TooltipVisible: 80ms show delay
        TooltipVisible --> Hovering: mouse moves to tooltip
        TooltipVisible --> Idle: mouseleave (150ms debounce)
    }
```

### Template Structure

```html
<div
  class="segmented-budget-bar"
  :class="budgetClass"
  role="progressbar"
  :aria-valuenow="totalUsed"
  :aria-valuemax="totalBudget"
  :aria-label="`Token budget: ${formatCompact(totalUsed)} of ${formatCompact(totalBudget)} used`"
  tabindex="0"
  @mouseenter="onMouseEnter"
  @mouseleave="onMouseLeave"
  @focusin="onMouseEnter"
  @focusout="onMouseLeave"
>
  <!-- Budget label (mirrors existing RelayView budget-label) -->
  <div class="budget-label-row">
    <span>Budget</span>
    <span>{{ formatCompact(totalUsed) }} / {{ formatCompact(totalBudget) }}</span>
  </div>

  <!-- Segmented bar -->
  <div v-if="segments.length === 0" class="empty-placeholder">
    {{ t('relay.noTokenData') }}
  </div>
  <div v-else class="segments-container">
    <div
      v-for="seg in segments"
      :key="seg.profession"
      class="segment"
      :style="segmentStyle(seg)"
    />
  </div>

  <!-- Hover tooltip (inline, not separate component) -->
  <Transition name="tooltip-fade">
    <div
      v-if="showTooltip && tooltipEntries.length > 0"
      class="breakdown-tooltip"
      role="tooltip"
      @mouseenter="onTooltipEnter"
      @mouseleave="onMouseLeave"
    >
      <div class="tooltip-title">{{ t('relay.tokenBreakdown') }}</div>
      <div class="tooltip-divider" />

      <div
        v-for="entry in tooltipEntries"
        :key="entry.profession"
        class="tooltip-row"
      >
        <span class="color-dot" :style="{ background: entry.color }" />
        <span class="profession-name">{{ entry.profession }}</span>
        <div class="mini-bar-track">
          <div
            class="mini-bar-fill"
            :style="{ width: entry.percentage + '%', background: entry.color }"
          />
        </div>
        <span class="percentage-label">{{ entry.percentage }}%</span>
      </div>

      <div class="tooltip-divider" />
      <div class="tooltip-total">
        {{ formatCompact(totalUsed) }} / {{ formatCompact(totalBudget) }}
      </div>
    </div>
  </Transition>
</div>
```

### Script Logic

```typescript
import { computed, ref, type PropType } from 'vue'
import { useI18n } from 'vue-i18n'
import type { ProfessionSegment, TooltipBarEntry } from '@/composables/useProfessionSegments'

// Hover state
const isHovering = ref(false)
const showTooltip = ref(false)
let showTimer: ReturnType<typeof setTimeout> | null = null
let hideTimer: ReturnType<typeof setTimeout> | null = null

function onMouseEnter() {
  isHovering.value = true
  if (hideTimer) { clearTimeout(hideTimer); hideTimer = null }
  showTimer = setTimeout(() => { showTooltip.value = true }, 80)
}

function onMouseLeave() {
  isHovering.value = false
  if (showTimer) { clearTimeout(showTimer); showTimer = null }
  hideTimer = setTimeout(() => { showTooltip.value = false }, 150)
}

function onTooltipEnter() {
  // Cancel hide when mouse moves into tooltip itself
  if (hideTimer) { clearTimeout(hideTimer); hideTimer = null }
}

// Budget warning class
const budgetClass = computed(() => {
  if (!props.totalBudget) return ''
  const ratio = props.totalUsed / props.totalBudget
  if (ratio >= (props.dangerThreshold ?? 0.9)) return 'budget-danger'
  if (ratio >= (props.warnThreshold ?? 0.7)) return 'budget-warn'
  return ''
})

// Segment style: proportional to totalBudget (not totalUsed)
const segmentStyle = (seg: ProfessionSegment) => ({
  width: props.totalBudget > 0
    ? `${(seg.tokens / props.totalBudget) * 100}%`
    : '0%',
  backgroundColor: seg.color,
  minWidth: seg.tokens > 0 ? '2px' : '0',
})

// Format helper: 1234 → "1.2k"
function formatCompact(n: number): string {
  if (n >= 1000) return `${(n / 1000).toFixed(1)}k`
  return `${n}`
}
```

