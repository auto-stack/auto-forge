## Relay-D6 useGateInbox State Machine
**Status:** implemented
**Module:** `packages/auto-forge-ui/src/composables/useGateInbox.ts`
**Tags:** stack:frontend
**Depends on:** UiSystem-A1

```typescript
interface PendingGate {
  id: string
  type: 'session' | 'run'
  gateType: 'goal' | 'spec' | 'review'
  title: string
  profession: string
  since: number
  context: {
    sessionId?: string
    runId?: string
    sectionId?: string
    itemId?: string
  }
}

interface GateInboxState {
  pending: PendingGate[]
  active: PendingGate | null
  resolved: PendingGate[]
}

function registerGate(gate: PendingGate): void
function resolveGate(id: string): void
function dismissSecretary(): void
function snoozeGate(id: string, minutes: number): void
```

```
fn registerGate(gate):
    if active is null:
        active = gate
    else:
        pending.push(gate)

fn resolveGate(id):
    if active?.id == id:
        resolved.push(active)
        active = pending.shift() ?? null
    else:
        pending.remove(where g.id == id)
        resolved.push(g)

fn snoozeGate(id, minutes):
    if active?.id == id:
        pending.push(active)
        active = null
        setTimeout(() => registerGate(active), minutes * 60000)
```


