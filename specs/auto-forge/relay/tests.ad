    // Pre-fill professionTokens
    // Mock: { ..., profession_tokens: {} }
    // Assert: professionTokens.value is {}
  })

  // T22.9: loadRun 覆盖而非累积
  it('should replace professionTokens on successive loadRun calls', async () => {
    // loadRun(A) -> { architect: 1000 }
    // loadRun(B) -> { coder: 500 }
    // Assert: only coder: 500, architect gone
